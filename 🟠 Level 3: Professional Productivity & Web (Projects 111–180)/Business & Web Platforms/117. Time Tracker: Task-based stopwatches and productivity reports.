# time_tracker.py
import time

class TimeTracker:
    def __init__(self, task_name):
        self.task_name = task_name
        self.start_time = None

    def start(self):
        self.start_time = time.time()

    def stop(self):
        elapsed = round(time.time() - self.start_time, 2)
        return f"Task '{self.task_name}' took {elapsed} seconds"

if __name__ == "__main__":
    tracker = TimeTracker("Write report")
    tracker.start()
    time.sleep(2)
    print(tracker.stop())
