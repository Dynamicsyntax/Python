# online_exam.py
import time

questions = [
    {"q": "2+2?", "a": "4"},
    {"q": "Capital of Italy?", "a": "Rome"}
]

def exam(duration=10):
    start = time.time()
    for q in questions:
        if time.time() - start > duration:
            print("Time up! Auto-submitted.")
            break
        ans = input(q["q"] + " ")
        print("Correct!" if ans == q["a"] else "Wrong!")

if __name__ == "__main__":
    exam()
