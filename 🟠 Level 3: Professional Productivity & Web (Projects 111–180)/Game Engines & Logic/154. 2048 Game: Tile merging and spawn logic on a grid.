# 🎮 2048 Game
# Simplified tile merging logic.

def merge_left(row):
    new = [i for i in row if i!=0]
    for i in range(len(new)-1):
        if new[i]==new[i+1]:
            new[i]*=2
            new[i+1]=0
    new = [i for i in new if i!=0]
    return new+[0]*(len(row)-len(new))

if __name__ == "__main__":
    row = [2,2,4,0]
    print("Before:", row)
    print("After:", merge_left(row))
