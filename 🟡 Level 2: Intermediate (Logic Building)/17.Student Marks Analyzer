# 🎓 Student Marks Analyzer

def calculate_grade(marks):
    if marks > 100 or marks < 0:
        return "❌ Invalid Marks"
    elif marks >= 90:
        return "A+"
    elif marks >= 80:
        return "A"
    elif marks >= 70:
        return "B"
    elif marks >= 60:
        return "C"
    elif marks >= 50:
        return "D"
    else:
        return "F"

# Step 1: Collect marks
marks_list = []
count = int(input("Enter number of subjects: "))

for i in range(count):
    mark = float(input(f"Enter marks for subject {i+1} (out of 100): "))
    marks_list.append(mark)

# Step 2: Display entered marks
print(f"\nYou entered: {marks_list}")

# Step 3: Calculate average
average_marks = sum(marks_list) / len(marks_list)

# Step 4: Determine grade
grade = calculate_grade(average_marks)

# Step 5: Show results
print(f"\n📊 Average Marks: {average_marks:.2f}")
print(f"🎓 Final Grade: {grade}")
