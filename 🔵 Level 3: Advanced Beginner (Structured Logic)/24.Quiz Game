# 🎮 Quiz Game

quiz = {
    "Capital of Pakistan?": "Islamabad",
    "2 + 2 = ?": "4",
    "Largest planet?": "Jupiter"
}

score = 0
for question, answer in quiz.items():
    user_answer = input(question + " ")
    if user_answer.strip().lower() == answer.lower():
        print("✅ Correct")
        score += 1
    else:
        print("❌ Wrong")

print(f"Final Score: {score}/{len(quiz)}")
