# 🌡️ Temperature Converter

check = input("Do you want to convert Celsius to Fahrenheit or Fahrenheit to Celsius? (c/f): ")

if check.lower() == 'c':
    celcius = float(input("Enter Temperature in Celsius: "))
    fahrenheit = celcius * (9/5) + 32
    print(f"{round(celcius,2)}°C is equal to {round(fahrenheit,2)}°F")

elif check.lower() == 'f':
    fahrenheit = float(input("Enter Temperature in Fahrenheit: "))
    celcius = (fahrenheit - 32) * (5/9)
    print(f"{round(fahrenheit,2)}°F is equal to {round(celcius,2)}°C")

else:
    print("❌ Invalid choice. Please enter 'c' or 'f'.")
