# 📝 Word Counter

sentence = input("Enter a Sentence to count its Number of Characters and Words: ")
spaces_count = input("Do you want to count spaces (y/n): ")

if spaces_count.lower() == 'y':
    ch_count = len(sentence)
    word_count = len(sentence.split())
else:
    ch_count = len(sentence.replace(" ", ""))
    word_count = len(sentence.split())

print(f"Number of Characters in the sentence: {ch_count}")
print(f"Number of Words in the sentence: {word_count}")
