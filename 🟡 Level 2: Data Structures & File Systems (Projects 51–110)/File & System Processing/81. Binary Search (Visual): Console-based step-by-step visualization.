#81. 🔍 Binary Search (Visual)
def binary_search_visual(arr, target):
    left, right = 0, len(arr)-1
    step = 1
    while left <= right:
        mid = (left+right)//2
        print(f"Step {step}: Left={left}, Right={right}, Mid={mid}, Value={arr[mid]}")
        if arr[mid] == target:
            return mid
        elif arr[mid] < target:
            left = mid+1
        else:
            right = mid-1
        step += 1
    return -1

nums = [1,3,5,7,9,11]
print("Result:", binary_search_visual(nums, 7))
