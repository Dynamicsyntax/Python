#57. 🎯 Subarray with Given Sum
arr = [1,4,20,3,10,5]
target = 33
curr_sum, start = 0, 0

for end in range(len(arr)):
    curr_sum += arr[end]
    while curr_sum > target and start < end:
        curr_sum -= arr[start]
        start += 1
    if curr_sum == target:
        print("Subarray:", arr[start:end+1])
        break
