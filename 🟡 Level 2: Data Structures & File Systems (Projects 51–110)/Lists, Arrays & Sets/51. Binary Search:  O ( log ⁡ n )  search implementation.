#51. 🔍 Binary Search Tool
# O(log n) search implementation

def binary_search(sorted_list, target):
    left, right = 0, len(sorted_list) - 1
    
    while left <= right:
        mid = (left + right) // 2
        mid_value = sorted_list[mid]
        
        if mid_value == target:
            return mid  # Found at index
        elif mid_value < target:
            left = mid + 1
        else:
            right = mid - 1
    
    return -1  # Not found

# Input from user
count = int(input("Enter how many numbers you want to enter (sorted order): "))
numbers = []

for i in range(count):
    number = int(input(f"Enter number {i+1}: "))
    numbers.append(number)

target = int(input("Enter the number to search: "))

# Perform binary search
result = binary_search(numbers, target)

if result != -1:
    print(f"✅ Found {target} at index {result} in {numbers}")
else:
    print(f"❌ {target} not found in {numbers}")
